{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/p-n-ai/oss/schema/assessments.schema.json",
  "title": "Assessments",
  "description": "Assessment questions for a topic",
  "type": "object",
  "required": ["topic_id", "questions", "provenance"],
  "properties": {
    "topic_id": {
      "type": "string",
      "description": "Reference to the topic these questions assess"
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "description": "List of assessment questions for this topic",
      "items": {
        "type": "object",
        "required": ["id", "text", "difficulty", "learning_objective", "answer", "marks"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^Q[0-9]+$",
            "description": "Question ID in Qnn format (e.g., Q01, Q02)"
          },
          "text": {
            "type": "string",
            "description": "Question text, supports LaTeX via $...$"
          },
          "difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard"],
            "description": "Question difficulty level"
          },
          "learning_objective": {
            "type": "string",
            "description": "References a learning objective ID from the topic (e.g., LO01, 1.1.1)"
          },
          "tp_level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6,
            "description": "Tahap Penguasaan level (1-6) this question assesses"
          },
          "kbat": {
            "type": "boolean",
            "description": "True if the question is a Higher Order Thinking Skills (KBAT) question"
          },
          "answer": {
            "type": "object",
            "required": ["type", "value"],
            "description": "The correct answer and solution details",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["exact", "range", "multiple_choice", "free_text"],
                "description": "Answer type: exact (single correct value), range (acceptable range), multiple_choice (one of options), or free_text (open-ended)"
              },
              "value": {
                "type": "string",
                "description": "The correct answer value. For multiple_choice, this is the correct option key (e.g., A, B)"
              },
              "working": {
                "type": "string",
                "description": "Step-by-step solution showing how to arrive at the answer"
              },
              "options": {
                "description": "Answer options for multiple_choice questions — either an array of strings or an object mapping keys to option text",
                "oneOf": [
                  {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  }
                ]
              },
              "distractors": {
                "type": "array",
                "description": "Common wrong answers with targeted feedback explaining why each is incorrect",
                "items": {
                  "type": "object",
                  "required": ["value", "feedback"],
                  "properties": {
                    "value": {
                      "type": "string",
                      "description": "A common incorrect answer"
                    },
                    "feedback": {
                      "type": "string",
                      "description": "Explanation of why this answer is wrong and what misconception it reflects"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "marks": {
            "type": "integer",
            "minimum": 1,
            "description": "Total marks allocated to this question"
          },
          "rubric": {
            "type": "array",
            "description": "Mark scheme breakdown showing how marks are awarded for each step",
            "items": {
              "type": "object",
              "required": ["marks", "criteria"],
              "properties": {
                "marks": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Number of marks awarded for meeting this criterion"
                },
                "criteria": {
                  "type": "string",
                  "description": "What the student must demonstrate to earn these marks"
                }
              },
              "additionalProperties": false
            }
          },
          "hints": {
            "type": "array",
            "description": "Progressive hints to guide students who are stuck, ordered from least to most revealing",
            "items": {
              "type": "object",
              "required": ["level", "text"],
              "properties": {
                "level": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Hint level (1=most subtle, higher=more direct)"
                },
                "text": {
                  "type": "string",
                  "description": "The hint text to show the student"
                }
              },
              "additionalProperties": false
            }
          },
          "distractors": {
            "type": "array",
            "description": "Common wrong answers with feedback (top-level alternative to answer.distractors)",
            "items": {
              "type": "object",
              "required": ["value", "feedback"],
              "properties": {
                "value": {
                  "type": "string",
                  "description": "A common incorrect answer"
                },
                "feedback": {
                  "type": "string",
                  "description": "Explanation of why this answer is wrong and what misconception it reflects"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "provenance": {
      "type": "string",
      "enum": ["human", "ai-assisted", "ai-generated", "ai-observed"],
      "description": "How this content was created: human, ai-assisted, ai-generated, or ai-observed"
    }
  },
  "additionalProperties": false
}
